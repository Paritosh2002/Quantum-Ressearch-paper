      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import warnings\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.model_selection import train_test_split\n",
        "import os\n",
        "\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# CONFIGURATION\n",
        "\n",
        "CONFIG = {\n",
        "    'missing_cell_threshold': 0.20,      # Remove cells with >20% missing genes\n",
        "    'missing_gene_threshold': 0.30,      # Remove genes with >30% missing cells\n",
        "    'reference_gene': 'GAPDH',           # Reference gene for ΔCt (adjust as needed)\n",
        "    'test_size': 0.20,                   # Train/test split ratio (for reference)\n",
        "    'random_state': 42,\n",
        "}\n",
        "\n",
        "# STEP 1: LOAD DATA\n",
        "file_path = \"/content/GSE84507_transposed_final.csv.xlsx\"\n",
        "\n",
        "def load_data(file_path):\n",
        "    \"\"\"Load raw Ct data and inspect.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 1: LOADING DATA\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    # Load the data\n",
        "    df = pd.read_excel(file_path, sheet_name=0, header=0)\n",
        "\n",
        "    # Clean column names: strip leading/trailing quotes and whitespace\n",
        "    df.columns = df.columns.str.strip().str.replace('\"', '')\n",
        "\n",
        "    # Identify gene columns (assuming Sample_ID and Treatment_Status are metadata)\n",
        "    all_cols = df.columns.tolist()\n",
        "    metadata_cols = ['Sample_ID', 'Treatment_Status'] # These are known metadata columns\n",
        "    gene_cols = [col for col in all_cols if col not in metadata_cols]\n",
        "\n",
        "    # Convert gene columns to numeric, coercing errors (e.g., if any values like '40\"' exist)\n",
        "    for col in gene_cols:\n",
        "        df[col] = pd.to_numeric(df[col].astype(str).str.strip().str.replace('\"', ''), errors='coerce')\n",
        "\n",
        "    print(f\" Loaded {df.shape[0]} cells (rows) and {df.shape[1]} columns\")\n",
        "    print(f\"   Columns: {df.columns[:5].tolist()}... (showing first 5)\")\n",
        "\n",
        "    # Basic stats\n",
        "    print(f\"\\n Basic Statistics:\")\n",
        "    print(f\"   - Sample IDs: {df.shape[0]}\")\n",
        "    print(f\"   - Genes: {len(gene_cols)}\") # Use cleaned gene_cols for count\n",
        "\n",
        "    # Check for special samples (noRT controls)\n",
        "    if 'Sample_ID' in df.columns:\n",
        "        noRT_samples = df[df['Sample_ID'].astype(str).str.contains('noRT', case=False, na=False)]\n",
        "        if len(noRT_samples) > 0:\n",
        "            print(f\"    Found {len(noRT_samples)} 'noRT' control samples - these will be included\")\n",
        "\n",
        "    return df\n",
        "\n",
        "# STEP 2: EXTRACT PHASE LABELS\n",
        "\n",
        "def extract_phase_labels(df):\n",
        "    \"\"\"Extract phase labels from sample names.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 2: EXTRACTING PHASE LABELS\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    df_copy = df.copy()\n",
        "\n",
        "    # Identify sample ID column\n",
        "    sample_col = 'Sample_ID' if 'Sample_ID' in df_copy.columns else df_copy.columns[0]\n",
        "\n",
        "    def get_phase(sample_name):\n",
        "        \"\"\"Extract phase from sample name.\"\"\"\n",
        "        if pd.isna(sample_name):\n",
        "            return 'unknown'\n",
        "\n",
        "        sample_str = str(sample_name).upper()\n",
        "\n",
        "        # Check for TKI (post-treatment)\n",
        "        if 'TKI' in sample_str:\n",
        "            return 'TKI'\n",
        "\n",
        "        # Check for Dx / D (diagnosis)\n",
        "        # D.P0, D.P1, etc. or standalone D\n",
        "        if '.D' in sample_str or ' D ' in sample_str or sample_str.endswith('D'):\n",
        "            # Make sure it's not \"noRT\" which might have D in it\n",
        "            if 'NORT' not in sample_str:\n",
        "                return 'Dx'\n",
        "\n",
        "        # If it has \"noRT\" it's still either Dx or TKI but noRT\n",
        "        if 'NORT' in sample_str:\n",
        "            if 'TKI' in sample_str:\n",
        "                return 'TKI'\n",
        "            else:\n",
        "                return 'Dx'\n",
        "\n",
        "        # Everything else is nBM (healthy control / normal bone marrow)\n",
        "        return 'nBM'\n",
        "\n",
        "    # Apply to get phases\n",
        "    df_copy['Phase'] = df_copy[sample_col].apply(get_phase)\n",
        "\n",
        "    # Show distribution\n",
        "    phase_counts = df_copy['Phase'].value_counts()\n",
        "    print(f\"\\n Phase labels extracted:\")\n",
        "    for phase, count in phase_counts.items():\n",
        "        print(f\"   - {phase}: {count} cells ({count/len(df_copy)*100:.1f}%)\")\n",
        "\n",
        "    # Add encoded phase for ML\n",
        "    phase_map = {'nBM': 0, 'Dx': 1, 'TKI': 2}\n",
        "    df_copy['Phase_Encoded'] = df_copy['Phase'].map(phase_map)\n",
        "\n",
        "    return df_copy\n",
        "\n",
        "# STEP 3: REMOVE SPARSE ROWS/COLUMNS\n",
        "\n",
        "def remove_sparse_data(df, gene_cols):\n",
        "    \"\"\"Remove cells and genes with too many missing values.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 3: REMOVING SPARSE DATA\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    df_clean = df.copy()\n",
        "\n",
        "    # Identify gene columns\n",
        "    sample_col = 'Sample_ID' if 'Sample_ID' in df_clean.columns else df_clean.columns[0]\n",
        "    all_cols = df_clean.columns.tolist()\n",
        "    metadata_cols = [sample_col, 'Treatment_Status', 'Phase', 'Phase_Encoded']\n",
        "    gene_cols = [col for col in all_cols if col not in metadata_cols]\n",
        "\n",
        "    # Initial counts\n",
        "    n_cells_initial = len(df_clean)\n",
        "    n_genes_initial = len(gene_cols)\n",
        "\n",
        "    print(f\"\\n Initial data:\")\n",
        "    print(f\"   - Cells: {n_cells_initial}\")\n",
        "    print(f\"   - Genes: {n_genes_initial}\")\n",
        "\n",
        "    # STEP 3a: Remove cells with >X% missing genes\n",
        "    missing_per_cell = df_clean[gene_cols].isnull().mean(axis=1)\n",
        "    cells_to_keep = missing_per_cell <= CONFIG['missing_cell_threshold']\n",
        "    df_clean = df_clean[cells_to_keep]\n",
        "\n",
        "    cells_removed = n_cells_initial - len(df_clean)\n",
        "    print(f\"\\n Removed {cells_removed} cells with >{CONFIG['missing_cell_threshold']*100:.0f}% missing genes\")\n",
        "    print(f\"   Remaining cells: {len(df_clean)}\")\n",
        "\n",
        "    # STEP 3b: Remove genes with >Y% missing cells\n",
        "    missing_per_gene = df_clean[gene_cols].isnull().mean()\n",
        "    genes_to_keep = missing_per_gene <= CONFIG['missing_gene_threshold']\n",
        "    genes_kept = [col for col, keep in zip(gene_cols, genes_to_keep) if keep]\n",
        "    genes_removed = [col for col, keep in zip(gene_cols, genes_to_keep) if not keep]\n",
        "\n",
        "    df_clean = df_clean[['Sample_ID', 'Treatment_Status', 'Phase', 'Phase_Encoded'] + genes_kept]\n",
        "\n",
        "    print(f\"\\n Removed {len(genes_removed)} genes with >{CONFIG['missing_gene_threshold']*100:.0f}% missing cells\")\n",
        "    print(f\"   Remaining genes: {len(genes_kept)}\")\n",
        "\n",
        "    # Update gene_cols\n",
        "    gene_cols = genes_kept\n",
        "\n",
        "    # Show final stats\n",
        "    print(f\"\\n After sparse removal:\")\n",
        "    print(f\"   - Cells: {len(df_clean)} (removed {cells_removed})\")\n",
        "    print(f\"   - Genes: {len(gene_cols)} (removed {len(genes_removed)}) fidelity is still maintained)\")\n",
        "\n",
        "    # Missing values after cleaning\n",
        "    missing_after = df_clean[gene_cols].isnull().sum().sum()\n",
        "    total_cells = len(df_clean) * len(gene_cols)\n",
        "    print(f\"   - Missing values: {missing_after} ({missing_after/total_cells*100:.2f}%) (This means the missing values are within acceptable threshold or have been handled)\")\n",
        "\n",
        "    return df_clean, gene_cols\n",
        "\n",
        "# STEP 4: COMPUTE ΔCt AND CONVERT TO RELATIVE EXPRESSION\n",
        "\n",
        "def compute_relative_expression(df, gene_cols, reference_gene):\n",
        "    \"\"\"Convert Ct values to relative expression using ΔCt method.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 4: CONVERTING Ct TO RELATIVE EXPRESSION\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    df_expr = df.copy()\n",
        "\n",
        "    # Check if reference gene exists\n",
        "    if reference_gene not in gene_cols:\n",
        "        print(f\" Reference gene '{reference_gene}' not found in data!\")\n",
        "        print(f\"   Available genes: {gene_cols[:10]}...\")\n",
        "\n",
        "        # Use a different reference or compute global average\n",
        "        print(\"   Using global average Ct as reference (per cell)...\")\n",
        "\n",
        "        # Compute ΔCt using mean of all genes in each cell\n",
        "        for col in gene_cols:\n",
        "            # Replace any remaining NaN with the gene's median (should be minimal after cleaning)\n",
        "            median_val = df_expr[col].median()\n",
        "            df_expr[col] = df_expr[col].fillna(median_val)\n",
        "\n",
        "        # Compute mean Ct per cell\n",
        "        cell_means = df_expr[gene_cols].mean(axis=1)\n",
        "\n",
        "        # Compute ΔCt (gene - mean_cell)\n",
        "        for col in gene_cols:\n",
        "            df_expr[col] = df_expr[col] - cell_means\n",
        "\n",
        "        print(f\" Used mean Ct per cell as reference\")\n",
        "\n",
        "    else:\n",
        "        print(f\" Using '{reference_gene}' as reference gene\")\n",
        "\n",
        "        # Fill any remaining NaN in reference gene (should be rare)\n",
        "        df_expr[reference_gene] = df_expr[reference_gene].fillna(df_expr[reference_gene].median())\n",
        "\n",
        "        # Compute ΔCt (gene - reference_gene)\n",
        "        for col in gene_cols:\n",
        "            # Fill any remaining NaN with gene median\n",
        "            df_expr[col] = df_expr[col].fillna(df_expr[col].median())\n",
        "            df_expr[col] = df_expr[col] - df_expr[reference_gene]\n",
        "\n",
        "    # Convert to relative expression: 2^(-ΔCt)\n",
        "    print(\"\\n Converting ΔCt to relative expression (2^(-ΔCt))...\")\n",
        "    for col in gene_cols:\n",
        "        df_expr[col] = 2 ** (-df_expr[col])\n",
        "\n",
        "    print(\" Relative expression computed\")\n",
        "\n",
        "    # Check for invalid values\n",
        "    invalid = (df_expr[gene_cols] == np.inf).sum().sum() + (df_expr[gene_cols] == -np.inf).sum().sum()\n",
        "    if invalid > 0:\n",
        "        print(f\" Found {invalid} infinite values, replacing with NaN...\")\n",
        "        df_expr[gene_cols] = df_expr[gene_cols].replace([np.inf, -np.inf], np.nan)\n",
        "        # Fill with column median\n",
        "        for col in gene_cols:\n",
        "            df_expr[col] = df_expr[col].fillna(df_expr[col].median())\n",
        "\n",
        "    # Show range of expression values\n",
        "    all_values = df_expr[gene_cols].values.flatten()\n",
        "    all_values = all_values[~np.isnan(all_values)]\n",
        "    print(f\"\\n Relative expression range: {all_values.min():.4f} to {all_values.max():.4f}\")\n",
        "    print(f\"   Mean: {all_values.mean():.4f}, Median: {np.median(all_values):.4f}\")\n",
        "\n",
        "    return df_expr\n",
        "\n",
        "# STEP 5: LOG-TRANSFORM\n",
        "\n",
        "def log_transform(df, gene_cols):\n",
        "    \"\"\"Apply log2 transformation to expression data.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 5: LOG-TRANSFORMING\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    df_log = df.copy()\n",
        "\n",
        "    # Apply log2 (handle zeros and negatives)\n",
        "    print(\" Applying log2 transformation...\")\n",
        "\n",
        "    # Add a small constant to avoid log(0) or log(negative)\n",
        "    # Find minimum value and add 1% of range\n",
        "    all_values = df_log[gene_cols].values.flatten()\n",
        "    all_values = all_values[~np.isnan(all_values)]\n",
        "    min_val = all_values.min()\n",
        "    range_val = all_values.max() - min_val\n",
        "    epsilon = max(1e-10, abs(min_val) * 0.01 + 1e-10)\n",
        "\n",
        "    print(f\"   Adding epsilon: {epsilon:.6f} to avoid log(0) or log(negative)\")\n",
        "\n",
        "    for col in gene_cols:\n",
        "        df_log[col] = np.log2(df_log[col] + epsilon)\n",
        "\n",
        "    print(\" Log2 transformation applied\")\n",
        "\n",
        "    # Show new range\n",
        "    all_values = df_log[gene_cols].values.flatten()\n",
        "    all_values = all_values[~np.isnan(all_values)]\n",
        "    print(f\"\\n Log-transformed range: {all_values.min():.4f} to {all_values.max():.4f}\")\n",
        "\n",
        "    return df_log\n",
        "\n",
        "# STEP 6: STANDARDIZE (Z-SCORE)\n",
        "\n",
        "def standardize_data(df, gene_cols):\n",
        "    \"\"\"Apply z-score standardization to each gene.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 6: STANDARDIZING (Z-SCORE)\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    df_std = df.copy()\n",
        "\n",
        "    print(\" Applying z-score standardization (mean=0, std=1 per gene)...\")\n",
        "\n",
        "    scaler = StandardScaler()\n",
        "    df_std[gene_cols] = scaler.fit_transform(df_std[gene_cols])\n",
        "\n",
        "    print(\" Standardization applied\")\n",
        "\n",
        "    # Show new statistics\n",
        "    all_values = df_std[gene_cols].values.flatten()\n",
        "    all_values = all_values[~np.isnan(all_values)]\n",
        "    print(f\"\\n Standardized range: {all_values.min():.4f} to {all_values.max():.4f}\")\n",
        "    print(f\"   Mean: {all_values.mean():.4f}, Std: {all_values.std():.4f}\")\n",
        "\n",
        "    return df_std, scaler\n",
        "\n",
        "# STEP 7: SAVE CLEANED DATA\n",
        "\n",
        "def save_cleaned_data(df, output_file='output.csv'):\n",
        "    \"\"\"Save the final cleaned dataset.\"\"\"\n",
        "    print(\"\\n\" + \"=\"*60)\n",
        "    print(\"STEP 7: SAVING CLEANED DATA\")\n",
        "    print(\"=\"*60)\n",
        "\n",
        "    # Save to CSV\n",
        "    df.to_csv(output_file, index=False)\n",
        "    print(f\" Saved cleaned data to: {output_file}\")\n",
        "    print(f\"   Shape: {df.shape}\")\n",
        "    print(f\"   Columns: {df.columns[:10].tolist()}... (showing first 10)\")\n",
        "\n",
        "    # Also save a version with just the expression data (no metadata)\n",
        "    expression_cols = [col for col in df.columns if col not in ['Sample_ID', 'Treatment_Status', 'Phase', 'Phase_Encoded']]\n",
        "    df_expr = df[['Sample_ID', 'Phase'] + expression_cols]\n",
        "    expr_file = output_file.replace('.csv', '_expression_only.csv')\n",
        "    df_expr.to_csv(expr_file, index=False)\n",
        "    print(f\" Saved expression-only data to: {expr_file}\")\n",
        "\n",
        "    return output_file\n",
        "\n",
        "# MAIN PIPELINE\n",
        "\n",
        "def main(file_path):\n",
        "    \"\"\"\n",
        "    Main preprocessing pipeline - clean and save.\n",
        "    \"\"\"\n",
        "    print(\"=\"*70)\n",
        "    print(\"GSE84507 DATA PREPROCESSING & CLEANING\")\n",
        "    print(\"=\"*70)\n",
        "    print(\"\\n Configuration:\")\n",
        "    for key, value in CONFIG.items():\n",
        "        print(f\"   {key}: {value}\")\n",
        "\n",
        "    # STEP 1: Load data\n",
        "    df = load_data(file_path)\n",
        "\n",
        "    # STEP 2: Extract phase labels\n",
        "    df = extract_phase_labels(df)\n",
        "\n",
        "    # Identify gene columns (after loading and initial cleaning in load_data)\n",
        "    sample_col = 'Sample_ID' if 'Sample_ID' in df.columns else df.columns[0]\n",
