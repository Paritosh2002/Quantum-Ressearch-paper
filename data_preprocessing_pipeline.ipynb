      "source": [
        "import pandas as pd\n",
        "import io\n",
        "\n",
        "\n",
        "with open('/content/GSE84507_non-normalized_data.csv', 'r', encoding='utf-8') as f:\n",
        "    content = f.read()\n",
        "# Split by newline to get lines\n",
        "lines = content.strip().split('\\n')\n",
        "\n",
        "# First line is the header\n",
        "header_line = lines[0]\n",
        "# Rest are data lines\n",
        "data_lines = lines[1:]\n",
        "\n",
        "# Parse header - split by tab\n",
        "headers = header_line.split('\\t')\n",
        "# The first header is 'ID_REF' (gene names)\n",
        "headers[0] = 'Gene'  # Rename for clarity\n",
        "\n",
        "# Parse data - each line is a gene with expression values\n",
        "data_rows = []\n",
        "for line in data_lines:\n",
        "    # Split each line by tab\n",
        "    values = line.split('\\t')\n",
        "    data_rows.append(values)\n",
        "\n",
        "# Create DataFrame: rows = genes, columns = samples\n",
        "df = pd.DataFrame(data_rows, columns=headers)\n",
        "df.set_index('Gene', inplace=True)\n",
        "\n",
        "print(f\"Original shape (genes={df.shape[0]}, samples={df.shape[1]}): {df.shape}\")\n",
        "\n",
        "# Transpose: now rows = samples, columns = genes\n",
        "df_transposed = df.T\n",
        "\n",
        "print(f\"Transposed shape (samples={df_transposed.shape[0]}, genes={df_transposed.shape[1]}): {df_transposed.shape}\")\n",
        "\n",
        "# Reset index to have Sample_ID as a column\n",
        "df_final = df_transposed.reset_index()\n",
        "df_final.rename(columns={'index': 'Sample_ID'}, inplace=True)\n",
        "\n",
        "# Create treatment status column\n",
        "df_final['Treatment_Status'] = df_final['Sample_ID'].str.extract(r'(D|TKI)')\n",
        "\n",
        "# Save the final dataset\n",
        "df_final.to_csv('GSE84507_transposed_final.csv', index=False)\n",
        "\n",
        "print(\"\\nFinal dataset saved successfully!\")\n",
        "print(f\"Final shape: {df_final.shape}\")\n",
        "print(\"\\nFirst few rows:\")\n",
        "print(df_final.head())"
      ],
